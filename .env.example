# === Database ===
DATABASE_URL=postgresql+asyncpg://sandbelt:yourpassword@localhost:5432/sandbelt_db
DATABASE_URL_SYNC=postgresql://sandbelt:yourpassword@localhost:5432/sandbelt_db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Google Earth Engine ===
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=secrets/gee-key.json

# === ERA5 CDS API ===
CDS_URL=https://cds.climate.copernicus.eu/api/v2
CDS_KEY=your-uid:your-api-key

# === LLM (RAG 问答, OpenAI-兼容接口) ===
# 默认指向中科院 uni-api (qwen3:235b); 换模型/服务商只改这三行
LLM_BASE_URL=https://uni-api.cstcloud.cn/v1
LLM_API_KEY=your-uni-api-key
LLM_MODEL=qwen3:235b
LLM_MAX_TOKENS=2048

# === RAG pipeline ===
RAG_EMBEDDER=BAAI/bge-m3
RAG_RERANKER=BAAI/bge-reranker-v2-m3
RAG_TOP_K_RETRIEVE=20
RAG_TOP_K_RERANK=5
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
CHROMA_PERSIST_DIR=backend/rag/chroma_store
RAG_DOCS_DIR=backend/rag/docs

# === OpenAI (Embedding, 可选) ===
OPENAI_API_KEY=sk-xxxxx

# === App ===
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# === Docker Compose (部署用, 本地开发可忽略) ===
# Postgres 初始化；首次 up -d 时生效, 改密码请同步改 DATABASE_URL
POSTGRES_DB=sandbelt_db
POSTGRES_USER=sandbelt
POSTGRES_PASSWORD=change-me-to-a-strong-password
# 宿主机端口映射 (需要改端口时用)
BACKEND_PORT=8000
FRONTEND_PORT=3000
# 前端打包时注入的后端地址；生产改成 http://<服务器公网IP>:8000 或 https://api.yourdomain.com
# 注意: Next.js 的 NEXT_PUBLIC_* 变量在 build 时 inline, 改完必须重新 build
NEXT_PUBLIC_API_URL=http://localhost:8000
